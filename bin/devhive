#!/usr/bin/env bash
# devhive — DevHive CLI (Go binary)
set -e

# Resolve the Go binary
find_binary() {
    if [ -n "$DEVHIVE_HOME" ] && [ -x "$DEVHIVE_HOME/bin/devhive.bin" ]; then
        echo "$DEVHIVE_HOME/bin/devhive.bin"
        return
    fi
    if [ -x "$HOME/.devhive/bin/devhive" ]; then
        echo "$HOME/.devhive/bin/devhive"
        return
    fi
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    if [ -x "$SCRIPT_DIR/devhive.bin" ]; then
        echo "$SCRIPT_DIR/devhive.bin"
        return
    fi
    echo ""
}

BIN=$(find_binary)
if [ -z "$BIN" ]; then
    echo "DevHive: Go binary not found." >&2
    echo "  Run: npm install -g @oswaldzsh/devhive" >&2
    exit 1
fi

# Bridge shell variables to environment for the Go binary.
# The Go client checks ANTHROPIC_AUTH_TOKEN and LEJU_TOKEN env vars.
if [ -z "$ANTHROPIC_AUTH_TOKEN" ] && [ -n "$LEJU_TOKEN" ]; then
    export ANTHROPIC_AUTH_TOKEN="$LEJU_TOKEN"
fi

exec "$BIN" "$@"
